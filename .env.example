# Django / database
DJANGO_SECRET_KEY=<set-django-secret-key>
MYSQL_PASSWORD=<set-mysql-password>
MYSQL_ROOT_PASSWORD=<set-mysql-root-password>

# Demo accounts
DEMO_ADMIN_PASSWORD=<set-demo-admin-password>
DEMO_ANALYST_PASSWORD=<set-demo-analyst-password>

# LLM: OpenAI-compatible chat completions
USE_LLM=0
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# RAG / Milvus
USE_MILVUS=1
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=literature_rag_chunks
RAG_EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
RAG_EMBEDDING_MODEL=embeddinggemma
RAG_EMBEDDING_API_KEY=ollama

# Academic API contact info, optional but recommended
NCBI_EMAIL=
CROSSREF_MAILTO=
