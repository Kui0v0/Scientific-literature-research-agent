DJANGO_SECRET_KEY=<set-django-secret-key>
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DB_ENGINE=mysql
MYSQL_DATABASE=literature_agent
MYSQL_USER=agent
MYSQL_PASSWORD=<set-mysql-password>
MYSQL_ROOT_PASSWORD=<set-mysql-root-password>
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
DEMO_ADMIN_PASSWORD=<set-demo-admin-password>
DEMO_ANALYST_PASSWORD=<set-demo-analyst-password>
USE_LLM=0
LLM_PROVIDER=openai
LLM_PROVIDER_NAME=GPT
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
LLM_REQUEST_TIMEOUT=60
LLM_HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
LLM_ACCEPT_LANGUAGE=zh-CN,zh;q=0.9,en;q=0.8
LLM_MAX_TOKENS=1600
LLM_USE_JSON_MODE=0
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
RAG_TOP_K=5
RAG_ABSTRACT_CHARS=480
RAG_REVIEW_TOP_K=5
RAG_ANALYSIS_TOP_K=5
RAG_EXPERIMENT_TOP_K=5
RAG_WRITING_TOP_K=5
RAG_REPORT_TOP_K=6
RAG_VECTOR_TOP_K=8
RAG_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
RAG_EMBEDDING_MODEL=embeddinggemma
RAG_EMBEDDING_API_KEY=ollama
RAG_EMBEDDING_TIMEOUT=30
RAG_RERANK_ENABLED=0
RAG_RERANK_MODEL_PATH=
RAG_RERANK_LOCAL_ONLY=1
RAG_RERANK_MAX_LENGTH=512
LLM_REVIEW_MAX_TOKENS=2800
LLM_KEYWORD_MAX_TOKENS=260
LLM_ANALYSIS_MAX_TOKENS=1500
LLM_EXPERIMENT_MAX_TOKENS=1600
LLM_WRITING_MAX_TOKENS=1300
LLM_REPORT_MAX_TOKENS=2200
USE_MILVUS=1
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=literature_rag_chunks
MILVUS_VECTOR_DIM=768
MILVUS_METRIC_TYPE=IP
MILVUS_INDEX_TYPE=FLAT
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_SECURE=0
NCBI_TOOL=literature_agent_demo
NCBI_EMAIL=
NCBI_API_KEY=
CROSSREF_MAILTO=
EXTERNAL_REQUEST_TIMEOUT=15
HTTP_USER_AGENT=literature-agent-demo/1.0
SSL_CERT_FILE=
